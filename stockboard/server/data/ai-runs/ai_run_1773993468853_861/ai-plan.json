      "text": "successfully purchased"
    },
    {
      "type": "nav",
      "testId": "nav-portfolio"
    },
    {
      "type": "expectVisible",
      "testId": "portfolio-holdings-table"
    },
    {
      "type": "expectVisible",
      "testId": "holding-row-AAPL"
    },
    {
      "type": "expectTextContains",
      "testId": "holding-row-AAPL",
      "text": "10 shares"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "toggleWatchlist",
      "symbol": "MSFT"
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "added to watchlist"
    },
    {
      "type": "nav",
      "testId": "nav-watchlist"
    },
    {
      "type": "expectVisible",
      "testId": "watch-toggle-MSFT"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "toggleWatchlist",
      "symbol": "MSFT"
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "removed from watchlist"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "selectStockInMarket",
      "symbol": "TSLA"
    },
    {
      "type": "buySelectedStock",
      "qty": 100000
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Insufficient funds"
    }
