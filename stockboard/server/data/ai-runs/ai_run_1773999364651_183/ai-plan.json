{
  "steps": [
    {
      "type": "depositToWallet",
      "amount": 10000
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Funds deposited successfully"
    },
    {
      "type": "expectTextContains",
      "testId": "wallet-balance",
      "text": "10,000"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "selectStockInMarket",
      "symbol": "MSFT"
    },
    {
      "type": "expectVisible",
      "testId": "ticket-side-buy"
    },
    {
      "type": "buySelectedStock",
      "qty": 10
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Stock bought successfully"
    },
    {
      "type": "nav",
      "testId": "nav-portfolio"
    },
    {
      "type": "expectVisible",
      "testId": "portfolio-holdings-table"
    },
    {
      "type": "expectVisible",
      "testId": "holding-row-MSFT"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "selectStockInMarket",
      "symbol": "GOOG"
    },
    {
      "type": "toggleWatchlist",
      "symbol": "GOOG"
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "added to watchlist"
    },
    {
      "type": "nav",
      "testId": "nav-watchlist"
    },
    {
      "type": "expectVisible",
      "testId": "watch-toggle-GOOG"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "selectStockInMarket",
      "symbol": "GOOG"
    },
    {
      "type": "toggleWatchlist",
      "symbol": "GOOG"
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "removed from watchlist"
    },
    {
      "type": "nav",
      "testId": "nav-watchlist"
    },
    {
      "type": "nav",
      "testId": "nav-market"
    },
    {
      "type": "selectStockInMarket",
      "symbol": "AAPL"
    },
    {
      "type": "buySelectedStock",
      "qty": 5
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Stock bought successfully"
    },
    {
      "type": "nav",
      "testId": "nav-portfolio"
    },
    {
      "type": "expectVisible",
      "testId": "holding-row-AAPL"
    },
    {
      "type": "depositToWallet",
      "amount": -500
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Funds withdrawn successfully"
    },
    {
      "type": "nav",
      "testId": "nav-logout"
    },
    {
      "type": "expectTextContains",
      "testId": "toast-message",
      "text": "Logged out successfully"
    }
  ]
}